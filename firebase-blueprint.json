{
  "entities": {
    "UserAccount": {
      "title": "UserAccount",
      "description": "App staff and administrative users",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique user ID" },
        "name": { "type": "string", "description": "User display name" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "role": { "type": "string", "enum": ["Administrator", "Accountant", "Teacher"], "description": "Staff access role" },
        "assignedClass": { "type": "string", "description": "Assigned class if the user is a Teacher" },
        "assignedClasses": { "type": "array", "description": "Assigned classes if the user is a Teacher with multiple gates" },
        "mfaEnabled": { "type": "boolean", "description": "Whether MFA is enabled or not" },
        "mfaSecret": { "type": "string", "description": "Secret token for MFA" }
      },
      "required": ["id", "name", "email", "role", "mfaEnabled"]
    },
    "Student": {
      "title": "Student",
      "description": "Registered students",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique student ID" },
        "name": { "type": "string", "description": "Student full name" },
        "class": { "type": "string", "description": "Assigned class grade" },
        "category": { "type": "string", "enum": ["Pre-school", "Primary", "JHS"], "description": "School level category" },
        "rollNumber": { "type": "string", "description": "Official roll code" },
        "active": { "type": "boolean", "description": "Student active status" },
        "guardianPhone": { "type": "string", "description": "Guardian phone contact code" },
        "photoUrl": { "type": "string", "description": "Base64 encoded student photo data or custom avatar url links" },
        "discount": { "type": "number", "description": "Optional daily check-in discount amount" },
        "gender": { "type": "string", "enum": ["Male", "Female"], "description": "Student gender" },
        "paymentType": { "type": "string", "enum": ["Daily", "Term"], "description": "Billing calculation model: daily vs static term subscription" },
        "termFee": { "type": "number", "description": "Fixed fee for entire school term for Term Payer" },
        "legacyDebt": { "type": "number", "description": "Pre-adoption / outstanding legacy debt to be integrated into system balance" }
      },
      "required": ["id", "name", "class", "category", "rollNumber", "active", "guardianPhone"]
    },
    "PaymentRecord": {
      "title": "PaymentRecord",
      "description": "Daily registration payments",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique payment ID" },
        "studentId": { "type": "string", "description": "Referenced student ID" },
        "studentName": { "type": "string", "description": "Student name at time of payment" },
        "class": { "type": "string", "description": "Class grade at payment time" },
        "category": { "type": "string", "description": "School level category at payment time" },
        "amount": { "type": "number", "description": "Paid amount in GHC" },
        "date": { "type": "string", "description": "Payment index date (YYYY-MM-DD)" },
        "timestamp": { "type": "string", "description": "ISO timestamp of check-in" },
        "collectedBy": { "type": "string", "description": "Name of collector" },
        "verified": { "type": "boolean", "description": "Instant verification status" }
      },
      "required": ["id", "studentId", "studentName", "class", "category", "amount", "date", "timestamp", "collectedBy", "verified"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Daily school expenses",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique expense ID" },
        "date": { "type": "string", "description": "Expense date (YYYY-MM-DD)" },
        "amount": { "type": "number", "description": "Expense amount in GHC" },
        "category": { "type": "string", "enum": ["Food", "Utilities", "Maintenance", "Transport", "Supplies", "Uniforms", "Others"], "description": "Expense category classification" },
        "description": { "type": "string", "description": "Details of the expense" },
        "approvedBy": { "type": "string", "description": "Name of approving staff member" },
        "timestamp": { "type": "string", "description": "ISO timestamp of creation" }
      },
      "required": ["id", "date", "amount", "category", "description", "approvedBy", "timestamp"]
    },
    "WorkerSalary": {
      "title": "WorkerSalary",
      "description": "Workers salary payments",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique salary payment ID" },
        "date": { "type": "string", "description": "Payment execution date (YYYY-MM-DD)" },
        "workerName": { "type": "string", "description": "Worker full name" },
        "userId": { "type": "string", "description": "Optional staff account ID" },
        "monthYear": { "type": "string", "description": "Reference month (e.g. June 2026)" },
        "role": { "type": "string", "description": "Worker job role" },
        "baseSalary": { "type": "number", "description": "Base salary in GHC" },
        "allowance": { "type": "number", "description": "Allowances / bonuses in GHC" },
        "deduction": { "type": "number", "description": "Deductions in GHC" },
        "netPaid": { "type": "number", "description": "Total net GHC paid" },
        "paymentMethod": { "type": "string", "enum": ["Cash", "Mobile Money", "Bank Transfer"], "description": "Mode of payment" },
        "notes": { "type": "string", "description": "Reference or personal notes" },
        "timestamp": { "type": "string", "description": "ISO timestamp of payment" }
      },
      "required": ["id", "date", "workerName", "monthYear", "role", "baseSalary", "allowance", "deduction", "netPaid", "paymentMethod", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserAccount",
      "description": "Collection of staff profiles"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Collection of pupil enrollment registry"
    },
    "/payments/{paymentId}": {
      "schema": "PaymentRecord",
      "description": "Collection of historical fee check-ins"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Collection of custom daily expenditures"
    },
    "/salaries/{salaryId}": {
      "schema": "WorkerSalary",
      "description": "Collection of tracking logs of employee wages"
    }
  }
}
