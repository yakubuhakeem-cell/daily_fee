# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ==========================================
# WHATSAPP API INTEGRATION SUITE
# ==========================================
# Set WHATSAPP_PROVIDER to toggle your preferred sending route: "meta", "twilio", "ultramsg", "custom", or keep empty for SIMULATION.
WHATSAPP_PROVIDER=""

# --- OPTION 1: META WHATSAPP CLOUD API (Direct/Official) ---
# Create a WhatsApp application on Meta Developers portal.
# Find your Phone Number ID and generate a Permanent Access Token.
WHATSAPP_PHONE_NUMBER_ID=""
# WHATSAPP_API_TOKEN: Your Meta developer access token
WHATSAPP_API_TOKEN=""

# --- OPTION 2: TWILIO WHATSAPP API (Developer Sandbox Friendly) ---
# Sign up on Twilio, get your Account SID and Auth Token, and join your sandbox number.
WHATSAPP_TWILIO_SID=""
WHATSAPP_TWILIO_AUTH_TOKEN=""
# WHATSAPP_SENDER_PHONE: Twilio sandbox number (e.g., "whatsapp:+14155238886")
WHATSAPP_SENDER_PHONE=""

# --- OPTION 3: QR-SCAN GATEWAYS (e.g. UltraMsg / Wassenger) ---
# No business verification needed! Sync your normal/business phone number by scanning a QR code.
# WHATSAPP_API_URL: API endpoint link (e.g., "https://api.ultramsg.com/instanceXXXX/messages/chat")
# WHATSAPP_API_TOKEN: Token provided by the dashboard
WHATSAPP_API_URL=""


